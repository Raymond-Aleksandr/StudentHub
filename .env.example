# Optional for local production builds targeting a GitHub Pages project site.
# Example: /your-repo-name/
VITE_BASE_PATH=

# Required for syllabus PDF import in deployed builds.
# If blank on localhost, the app uses http://127.0.0.1:8787/parse.
# If blank in production, the app uses the public demo Worker endpoint configured in source.
VITE_SYLLABUS_PARSER_URL=
